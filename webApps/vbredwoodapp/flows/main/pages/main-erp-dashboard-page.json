{
  "title": "ERP Projects Dashboard",
  "description": "Dashboard landing page for ERP project performance overview",
  "variables": {
    "pageTitle": {
      "type": "string",
      "defaultValue": "ERP Projects Dashboard"
    },
    "pageSubtitle": {
      "type": "string",
      "defaultValue": "Real-time overview of project performance and financials — FY 2025"
    },
    "selectedKpi": {
      "type": "string",
      "defaultValue": ""
    },
    "kpisArray": {
      "type": "any[]",
      "defaultValue": [
        {
          "id": "totalProjects",
          "title": "Total Projects",
          "metric": "142",
          "meta": "+8 this quarter"
        },
        {
          "id": "budgetUtilized",
          "title": "Budget Utilized",
          "metric": "$2.4M",
          "meta": "73% of total allocated"
        },
        {
          "id": "activeMilestones",
          "title": "Active Milestones",
          "metric": "36",
          "meta": "Due this month"
        },
        {
          "id": "overdueTasks",
          "title": "Overdue Tasks",
          "metric": "12",
          "meta": "Needs attention",
          "badge": { "status": "danger", "text": "Urgent" }
        }
      ]
    },
    "kpisADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "any",
        "keyAttributes": "id",
        "data": "{{ $page.variables.kpisArray }}"
      }
    },
    "barChartGroups": {
      "type": "any[]",
      "defaultValue": ["Capital", "Operations", "IT", "R&D", "Compliance"]
    },
    "barChartSeries": {
      "type": "any[]",
      "defaultValue": [
        {
          "name": "Budget",
          "color": "#1B6ACB",
          "items": [850, 320, 780, 450, 210]
        },
        {
          "name": "Actual",
          "color": "#00B399",
          "items": [620, 290, 510, 380, 195]
        }
      ]
    },
    "pieChartSeries": {
      "type": "any[]",
      "defaultValue": [
        {
          "name": "Status",
          "items": [
            { "value": 65, "label": "On Track",  "color": "#00B399" },
            { "value": 28, "label": "At Risk",   "color": "#F7A300" },
            { "value": 19, "label": "Delayed",   "color": "#E22134" },
            { "value": 30, "label": "Completed", "color": "#1B6ACB" }
          ]
        }
      ]
    },
    "lineChartGroups": {
      "type": "any[]",
      "defaultValue": ["Jan", "Feb", "Mar", "Apr", "May", "Jun"]
    },
    "lineChartSeries": {
      "type": "any[]",
      "defaultValue": [
        {
          "name": "Total Spend",
          "color": "#1B6ACB",
          "items": [280, 350, 420, 390, 510, 480]
        },
        {
          "name": "Budget Limit",
          "color": "#E22134",
          "lineStyle": "dashed",
          "items": [400, 400, 450, 450, 500, 500]
        }
      ]
    }
  },
  "metadata": {},
  "types": {},
  "chains": {},
  "eventListeners": {
    "vbEnter": {
      "chains": [
        {
          "chain": "vbEnterChain"
        }
      ]
    }
  },
  "imports": {
    "components": {
      "oj-sp-dashboard-landing-page": {
        "path": "oj-sp/dashboard-landing-page/loader"
      },
      "oj-sp-scoreboard": {
        "path": "oj-sp/scoreboard/loader"
      },
      "oj-sp-dashboard-grid": {
        "path": "oj-sp/dashboard-grid/loader"
      },
      "oj-sp-dashboard-panel": {
        "path": "oj-sp/dashboard-panel/loader"
      },
      "oj-chart": {
        "path": "ojs/ojchart"
      }
    }
  }
}
