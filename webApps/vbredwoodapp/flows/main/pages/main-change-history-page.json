          "label": "Today",
          "value": "2"
        },
        {
          "label": "This Week",
          "value": "5"
        },
        {
          "label": "Users",
          "value": "3"
        }
      ]
    },
    "badge": {
      "type": "object",
      "defaultValue": {
        "text": "Audit",
        "status": "info"
      }
    },
    "planHeader": {
      "type": "object",
      "defaultValue": {
        "projectName": "",
        "businessUnit": "",
        "projectOrg": "",
        "projectManager": ""
      }
    },
    "lastProjectNumber": {
      "type": "string",
      "defaultValue": ""
    },
    "projectMeta": {
      "type": "object",
      "defaultValue": {
        "P012025": {
          "projectName": "Pinnacle Park Project",
