      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "any",
        "keyAttributes": "id",
        "data": "{{ $page.variables.auditLinesArray }}"
      }
    },
    "projectNumberArray": {
      "type": "any[]",
      "defaultValue": [
        {
          "value": "P012025",
          "label": "P012025"
        },
        {
          "value": "P012026",
          "label": "P012026"
        }
      ]
    },
    "projectNumberADP": {
