          "value": "2"
        }
      ]
    },
    "badge": {
      "type": "object",
      "defaultValue": {
        "text": "Receiving",
        "status": "info"
      }
    },
    "planHeader": {
      "type": "object",
      "defaultValue": {
        "projectName": "",
        "businessUnit": "",
        "projectOrg": "",
        "projectManager": ""
      }
    },
    "lastProjectNumber": {
      "type": "string",
      "defaultValue": ""
    },
    "projectMeta": {
      "type": "object",
      "defaultValue": {
        "P012025": {
          "projectName": "Pinnacle Park Project",
