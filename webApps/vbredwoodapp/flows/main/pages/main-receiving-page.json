    "filterCriterion": {
      "type": "any"
    },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": {
        "url": "[[ $application.path + 'resources/data/receiving-search-config.json' ]]"
      }
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "ProjectNumberFilter": {
              "label": "Project Number",
              "options": {
                "optionsData": "[[ $page.variables.projectNumberADP ]]",
                "optionsKeys": {
                  "label": "label",
                  "value": "value"
                }
              }
            },
            "BusinessUnitFilter": {
              "label": "Business Unit",
              "options": {
                "optionsData": "[[ $page.variables.businessUnitADP ]]",
                "optionsKeys": {
                  "label": "label",
                  "value": "value"
                }
              }
            },
            "ProjectOrgFilter": {
              "label": "Project Organization",
              "options": {
                "optionsData": "[[ $page.variables.projectOrgADP ]]",
                "optionsKeys": {
                  "label": "label",
                  "value": "value"
                }
              }
            },
            "PONumberFilter": {
              "label": "PO Number",
              "options": {
                "optionsData": "[[ $page.variables.poNumberADP ]]",
                "optionsKeys": {
                  "label": "label",
                  "value": "value"
                }
              }
            }
          }
        }
