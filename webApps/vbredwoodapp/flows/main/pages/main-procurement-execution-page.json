{
  "title": "Procurement Execution",
  "description": "Create requisitions, POs and negotiations from ready plan lines. Project LOV + BU/Org cascade from direct Fusion REST (ORDS fallback); execution lines from ORDS getPDSCExecuteDetails. Mirrors the Project Procurement Plan page.",
  "variables": {
    "pageTitle": { "type": "string", "defaultValue": "Procurement Execution" },
    "pageSubtitle": { "type": "string", "defaultValue": "Create requisitions, POs and negotiations from ready plan lines" },

    "secondaryActions": {
      "type": "object[]",
      "defaultValue": [
        { "id": "purchaseRequisition", "label": "Purchase Requisition", "display": "on" },
        { "id": "purchaseOrder", "label": "Purchase Order", "display": "on" },
        { "id": "negotiation", "label": "Negotiation", "display": "on" },
        { "id": "initiateSupplyPlan", "label": "Initiate Supply Plan", "display": "on" }
      ]
    },

    "planHeader": {
      "type": "object",
      "defaultValue": { "projectNumber": "", "projectName": "", "businessUnit": "", "projectOrg": "", "status": "", "projectManager": "", "projectId": null, "buId": null, "orgId": null }
    },
    "lastProjectNumber": { "type": "string", "defaultValue": "" },
    "selectedKeys": { "type": "any" },

    "prDrawerOpen": { "type": "boolean", "defaultValue": false },
    "prSaving": { "type": "boolean", "defaultValue": false },
    "prForm": {
      "type": "object",
      "defaultValue": { "preparerId": null, "preparer": "", "requesterId": null, "requester": "", "destinationId": null, "destinationorgname": "" }
    },
    "prLinesArray": { "type": "any[]", "defaultValue": [] },
    "prLinesADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": { "itemType": "any", "keyAttributes": "execute_id", "data": "{{ $page.variables.prLinesArray }}" }
    },
    "personArray": { "type": "any[]", "defaultValue": [] },
    "personADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "person_id", "data": "{{ $page.variables.personArray }}" } },
    "destOrgArray": { "type": "any[]", "defaultValue": [] },
    "destOrgADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "organization_id", "data": "{{ $page.variables.destOrgArray }}" } },
    "prLovsLoadedFor": { "type": "string", "defaultValue": "" },

    "poDrawerOpen": { "type": "boolean", "defaultValue": false },
    "poSaving": { "type": "boolean", "defaultValue": false },
    "poForm": {
      "type": "object",
      "defaultValue": { "currencyCode": "", "buyer": "", "billToLocation": "", "supplier": "", "supplierSite": "", "supplierEmailAddress": "" }
    },
    "poLinesArray": { "type": "any[]", "defaultValue": [] },
    "poLinesADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "execute_id", "data": "{{ $page.variables.poLinesArray }}" } },
    "poCurrencyArray": { "type": "any[]", "defaultValue": [] },
    "poCurrencyADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "CurrencyCode", "data": "{{ $page.variables.poCurrencyArray }}" } },
    "poBuyerArray": { "type": "any[]", "defaultValue": [] },
    "poBuyerADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "Agent", "data": "{{ $page.variables.poBuyerArray }}" } },
    "poBillToArray": { "type": "any[]", "defaultValue": [] },
    "poBillToADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "OrganizationName", "data": "{{ $page.variables.poBillToArray }}" } },
    "poSupplierArray": { "type": "any[]", "defaultValue": [] },
    "poSupplierADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "vendor_name", "data": "{{ $page.variables.poSupplierArray }}" } },
    "poSiteArray": { "type": "any[]", "defaultValue": [] },
    "poSiteADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "vendor_site_code", "data": "{{ $page.variables.poSiteArray }}" } },
    "poEmailArray": { "type": "any[]", "defaultValue": [] },
    "poEmailADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "supplier_email_address", "data": "{{ $page.variables.poEmailArray }}" } },
    "poLovsLoadedFor": { "type": "string", "defaultValue": "" },

    "negDrawerOpen": { "type": "boolean", "defaultValue": false },
    "negSaving": { "type": "boolean", "defaultValue": false },
    "negForm": {
      "type": "object",
      "defaultValue": { "negotiationType": "", "negotiationStyle": "", "negotiationTemplate": "", "negotiationCurrency": "", "buyer": "", "title": "", "opendate": "", "closedate": "", "notetoSupplier": "" }
    },
    "negLinesArray": { "type": "any[]", "defaultValue": [] },
    "negLinesADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "execute_id", "data": "{{ $page.variables.negLinesArray }}" } },
    "negTypeArray": { "type": "any[]", "defaultValue": [] },
    "negTypeADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "negotiation_display_name", "data": "{{ $page.variables.negTypeArray }}" } },
    "negStyleArray": { "type": "any[]", "defaultValue": [] },
    "negStyleADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "style_name", "data": "{{ $page.variables.negStyleArray }}" } },
    "negTemplateArray": { "type": "any[]", "defaultValue": [] },
    "negTemplateADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "auction_title", "data": "{{ $page.variables.negTemplateArray }}" } },
    "negCurrencyArray": { "type": "any[]", "defaultValue": [] },
    "negCurrencyADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "CurrencyCode", "data": "{{ $page.variables.negCurrencyArray }}" } },
    "negBuyerArray": { "type": "any[]", "defaultValue": [] },
    "negBuyerADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "Agent", "data": "{{ $page.variables.negBuyerArray }}" } },
    "negLovsLoadedFor": { "type": "string", "defaultValue": "" },

    "execLinesArray": { "type": "any[]", "defaultValue": [] },
    "execLinesAllArray": { "type": "any[]", "defaultValue": [] },
    "execLinesADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": { "itemType": "any", "keyAttributes": "execute_id", "data": "{{ $page.variables.execLinesArray }}" }
    },

    "projectNumberArray": { "type": "any[]", "defaultValue": [] },
    "projectNumberADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "value", "data": "{{ $page.variables.projectNumberArray }}" } },
    "businessUnitArray": { "type": "any[]", "defaultValue": [] },
    "businessUnitADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "value", "data": "{{ $page.variables.businessUnitArray }}" } },
    "projectOrgArray": { "type": "any[]", "defaultValue": [] },
    "projectOrgADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "value", "data": "{{ $page.variables.projectOrgArray }}" } },
    "itemCategoryArray": { "type": "any[]", "defaultValue": [] },
    "itemCategoryADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "value", "data": "{{ $page.variables.itemCategoryArray }}" } },
    "criticalOptionsArray": { "type": "any[]", "defaultValue": [ { "value": "Yes", "label": "Yes" }, { "value": "No", "label": "No" } ] },
    "criticalOptionsADP": { "type": "vb/ArrayDataProvider2", "defaultValue": { "itemType": "any", "keyAttributes": "value", "data": "{{ $page.variables.criticalOptionsArray }}" } },

    "filterCriterion": { "type": "any" },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": { "url": "[[ $application.path + 'resources/data/proc-exec-search-config.json' ]]" }
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "ProjectNumberFilter": { "label": "Project Number", "options": { "optionsData": "[[ $page.variables.projectNumberADP ]]", "optionsKeys": { "label": "label", "value": "value" } } },
            "BusinessUnitFilter": { "label": "Business Unit", "options": { "optionsData": "[[ $page.variables.businessUnitADP ]]", "optionsKeys": { "label": "label", "value": "value" } } },
            "ProjectOrgFilter": { "label": "Project Organization", "options": { "optionsData": "[[ $page.variables.projectOrgADP ]]", "optionsKeys": { "label": "label", "value": "value" } } },
            "ItemCategoryFilter": { "label": "Item Category", "options": { "optionsData": "[[ $page.variables.itemCategoryADP ]]", "optionsKeys": { "label": "label", "value": "value" } } },
            "CriticalFilter": { "label": "Critical", "options": { "optionsData": "[[ $page.variables.criticalOptionsADP ]]", "optionsKeys": { "label": "label", "value": "value" } } }
          }
        }
      }
    }
  },
  "metadata": {},
  "types": {},
  "chains": {
    "secondaryActionChain": {
      "variables": { "detail": { "type": "any", "input": "fromCaller", "required": true } }
    }
  },
  "eventListeners": {
    "vbEnter": { "chains": [ { "chain": "vbEnterChain" } ] },
    "goToParentChain": { "chains": [ { "chain": "goToParentChain" } ] },
    "primaryActionChain": { "chains": [ { "chain": "primaryActionChain" } ] },
    "secondaryActionChain": { "chains": [ { "chain": "secondaryActionChain", "parameters": { "detail": "{{ $event.detail }}" } } ] },
    "filterCriterionChanged": { "chains": [ { "chain": "filterChain" } ] },
    "createRequisition": { "chains": [ { "chain": "createRequisition" } ] },
    "closePrDrawer": { "chains": [ { "chain": "closePrDrawer" } ] },
    "prPreparerChanged": { "chains": [ { "chain": "prPreparerChanged", "parameters": { "detail": "{{ $event.detail }}" } } ] },
    "prRequesterChanged": { "chains": [ { "chain": "prRequesterChanged", "parameters": { "detail": "{{ $event.detail }}" } } ] },
    "prDestOrgChanged": { "chains": [ { "chain": "prDestOrgChanged", "parameters": { "detail": "{{ $event.detail }}" } } ] },
    "createPurchaseOrder": { "chains": [ { "chain": "createPurchaseOrder" } ] },
    "closePoDrawer": { "chains": [ { "chain": "closePoDrawer" } ] },
    "poSupplierChanged": { "chains": [ { "chain": "poSupplierChanged", "parameters": { "detail": "{{ $event.detail }}" } } ] },
    "createNegotiation": { "chains": [ { "chain": "createNegotiation" } ] },
    "closeNegDrawer": { "chains": [ { "chain": "closeNegDrawer" } ] },
    "negTypeStyleChanged": { "chains": [ { "chain": "negTemplateCascade" } ] }
  },
  "imports": {
    "components": {
      "oj-sp-general-overview-page": { "path": "oj-sp/general-overview-page/loader" },
      "oj-sp-smart-search": { "path": "oj-sp/smart-search/loader" },
      "oj-table": { "path": "ojs/ojtable" },
      "oj-bind-text": { "path": "ojs/ojknockout" },
      "oj-bind-if": { "path": "ojs/ojknockout" },
      "oj-drawer-popup": { "path": "ojs/ojdrawerpopup" },
      "oj-form-layout": { "path": "ojs/ojformlayout" },
      "oj-select-single": { "path": "ojs/ojselectsingle" },
      "oj-input-text": { "path": "ojs/ojinputtext" },
      "oj-input-number": { "path": "ojs/ojinputnumber" },
      "oj-input-date": { "path": "ojs/ojdatetimepicker" },
      "oj-button": { "path": "ojs/ojbutton" }
    }
  }
}
