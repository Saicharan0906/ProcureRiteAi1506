        "itemType": "any",
        "keyAttributes": "value",
        "data": "{{ $page.variables.businessUnitArray }}"
      }
    },
    "projectOrgArray": {
      "type": "any[]",
      "defaultValue": [
        {
          "value": "Consulting US",
          "label": "Consulting US"
        },
        {
          "value": "OAK PPM",
          "label": "OAK PPM"
        }
      ]
    },
    "projectOrgADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "any",
        "keyAttributes": "value",
        "data": "{{ $page.variables.projectOrgArray }}"
      }
    }
