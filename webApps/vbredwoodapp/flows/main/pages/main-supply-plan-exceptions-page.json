        {
          "label": "Critical",
          "value": "2"
        },
        {
          "label": "Open",
          "value": "3"
        },
        {
          "label": "Resolved",
          "value": "2"
        }
      ]
    },
    "badge": {
      "type": "object",
      "defaultValue": {
        "text": "Exceptions",
        "status": "info"
      }
    },
    "planHeader": {
      "type": "object",
      "defaultValue": {
        "projectName": "",
        "businessUnit": "",
        "projectOrg": "",
        "projectManager": ""
      }
    },
    "lastProjectNumber": {
      "type": "string",
      "defaultValue": ""
    },
    "projectMeta": {
      "type": "object",
      "defaultValue": {
        "P012025": {
          "projectName": "Pinnacle Park Project",
          "businessUnits": [
            "US1 Business Unit"
          ],
          "orgs": [
            "Consulting US"
          ],
          "projectManager": "Rite Developer"
        },
        "P012026": {
          "projectName": "Riverside Expansion",
