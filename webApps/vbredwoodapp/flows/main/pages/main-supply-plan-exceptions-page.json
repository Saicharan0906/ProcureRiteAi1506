    "exceptionsAllArray": {
      "type": "any[]",
      "defaultValue": []
    },
    "exceptionsADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "any",
        "keyAttributes": "id",
        "data": "{{ $page.variables.exceptionsArray }}"
      }
    },
    "projectNumberArray": {
      "type": "any[]",
      "defaultValue": [
        {
          "value": "P012025",
          "label": "P012025"
        },
        {
          "value": "P012026",
          "label": "P012026"
        }
      ]
    },
    "projectNumberADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "any",
        "keyAttributes": "value",
        "data": "{{ $page.variables.projectNumberArray }}"
      }
    },
    "businessUnitArray": {
      "type": "any[]",
      "defaultValue": [
        {
          "value": "US1 Business Unit",
