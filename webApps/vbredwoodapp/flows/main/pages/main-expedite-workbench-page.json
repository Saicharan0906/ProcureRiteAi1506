{
  "title": "Expedite Workbench",
  "description": "Manage pre-receipt PO activities: supplier communication, schedule, documents, inspection, hold/release. Rebuilt fresh on Redwood. Mock data pending ORDS/Fusion.",
  "variables": {
    "pageTitle": { "type": "string", "defaultValue": "Expedite Workbench" },
    "pageSubtitle": { "type": "string", "defaultValue": "Track supplier communication, schedule, documents and inspection per PO line" },
    "contextualInfo": {
      "type": "any[]",
      "defaultValue": [
        { "label": "PO Lines", "value": "6" },
        { "label": "On Hold", "value": "1" },
        { "label": "WIP", "value": "2" },
        { "label": "Complete", "value": "2" }
      ]
    },
    "badge": { "type": "object", "defaultValue": { "text": "Expedite", "status": "info" } },
    "secondaryActions": {
      "type": "object[]",
      "defaultValue": [
        { "id": "hold", "label": "Hold", "icon": "oj-ux-ico-circle-pause", "display": "on" },
        { "id": "releaseHold", "label": "Release Hold", "icon": "oj-ux-ico-circle-play", "display": "on" },
        { "id": "email", "label": "Email Supplier", "icon": "oj-ux-ico-email", "display": "on" }
      ]
    },
    "planHeader": {
      "type": "object",
      "defaultValue": { "projectName": "", "businessUnit": "", "projectOrg": "", "status": "", "projectManager": "" }
    },
    "lastProjectNumber": { "type": "string", "defaultValue": "" },
    "projectMeta": {
      "type": "object",
      "defaultValue": {
        "P012025": { "projectName": "Pinnacle Park Project", "businessUnits": ["US1 Business Unit"], "orgs": ["Consulting US"], "status": "Expediting", "projectManager": "Rite Developer" },
        "P012026": { "projectName": "Riverside Expansion", "businessUnits": ["US1 Business Unit", "UK Business Unit"], "orgs": ["OAK PPM", "Consulting US"], "status": "Expediting", "projectManager": "A. Kumar" }
      }
    },

    "projectNumberArray": { "type": "any[]", "defaultValue": [
      { "value": "P012025", "label": "P012025" }, { "value": "P012026", "label": "P012026" } ] },
    "projectNumberADP": { "type": "vb/ArrayDataProvider2", "defaultValue": {
      "itemType": "any", "keyAttributes": "value", "data": "{{ $page.variables.projectNumberArray }}" } },

    "businessUnitArray": { "type": "any[]", "defaultValue": [
      { "value": "US1 Business Unit", "label": "US1 Business Unit" }, { "value": "UK Business Unit", "label": "UK Business Unit" } ] },
    "businessUnitADP": { "type": "vb/ArrayDataProvider2", "defaultValue": {
      "itemType": "any", "keyAttributes": "value", "data": "{{ $page.variables.businessUnitArray }}" } },

    "projectOrgArray": { "type": "any[]", "defaultValue": [
      { "value": "Consulting US", "label": "Consulting US" }, { "value": "OAK PPM", "label": "OAK PPM" } ] },
    "projectOrgADP": { "type": "vb/ArrayDataProvider2", "defaultValue": {
      "itemType": "any", "keyAttributes": "value", "data": "{{ $page.variables.projectOrgArray }}" } },

    "criticalOptionsArray": { "type": "any[]", "defaultValue": [
      { "value": "Yes", "label": "Yes" }, { "value": "No", "label": "No" } ] },
    "criticalOptionsADP": { "type": "vb/ArrayDataProvider2", "defaultValue": {
      "itemType": "any", "keyAttributes": "value", "data": "{{ $page.variables.criticalOptionsArray }}" } },

    "assigneeArray": { "type": "any[]", "defaultValue": [
      { "value": "Snehal", "label": "Snehal" }, { "value": "Veera", "label": "Veera" }, { "value": "Jack", "label": "Jack" } ] },
    "assigneeADP": { "type": "vb/ArrayDataProvider2", "defaultValue": {
      "itemType": "any", "keyAttributes": "value", "data": "{{ $page.variables.assigneeArray }}" } },

    "poSchedulesArray": {
      "type": "any[]",
      "defaultValue": [
        { "id": 1, "projectNumber": "P012025", "businessUnit": "US1 Business Unit", "projectOrg": "Consulting US", "critical": "Yes", "poNumber": "US165224", "itemNumber": "AS00106", "itemDescription": "Alliance 7 Pro", "itemCategory": "Software.Server", "supplier": "EIP Inc", "buyer": "Developer, Rite", "assignee": "Snehal", "promisedDate": "30-Apr-2025", "needByDate": "25-Apr-2025", "actualDate": "30-Apr-2025", "status": "Complete" },
        { "id": 2, "projectNumber": "P012025", "businessUnit": "US1 Business Unit", "projectOrg": "Consulting US", "critical": "No", "poNumber": "US165225", "itemNumber": "AS00106", "itemDescription": "Alliance 7 Pro", "itemCategory": "Software.Server", "supplier": "EIP Inc", "buyer": "AJITH", "assignee": "Snehal", "promisedDate": "30-Apr-2025", "needByDate": "28-Apr-2025", "actualDate": "", "status": "WIP" },
        { "id": 3, "projectNumber": "P012025", "businessUnit": "US1 Business Unit", "projectOrg": "Consulting US", "critical": "Yes", "poNumber": "US165226", "itemNumber": "AS00106", "itemDescription": "Alliance 7 Pro", "itemCategory": "Software.Server", "supplier": "FEC", "buyer": "Developer, Rite", "assignee": "Snehal", "promisedDate": "13-May-2025", "needByDate": "10-May-2025", "actualDate": "", "status": "On Hold" },
        { "id": 4, "projectNumber": "P012025", "businessUnit": "US1 Business Unit", "projectOrg": "Consulting US", "critical": "No", "poNumber": "US165233", "itemNumber": "AS00107", "itemDescription": "Alliance 7 Ultimate", "itemCategory": "Software.Server", "supplier": "EIP Inc", "buyer": "AJITH", "assignee": "Veera", "promisedDate": "30-Apr-2025", "needByDate": "29-Apr-2025", "actualDate": "30-Apr-2025", "status": "Complete" },
        { "id": 5, "projectNumber": "P012025", "businessUnit": "US1 Business Unit", "projectOrg": "Consulting US", "critical": "No", "poNumber": "US165234", "itemNumber": "AS00103", "itemDescription": "Blue Hat Enterprise", "itemCategory": "Hardware.Network", "supplier": "FEC", "buyer": "Developer, Rite", "assignee": "Veera", "promisedDate": "15-May-2025", "needByDate": "12-May-2025", "actualDate": "", "status": "Assigned" },
        { "id": 6, "projectNumber": "P012025", "businessUnit": "US1 Business Unit", "projectOrg": "Consulting US", "critical": "No", "poNumber": "US165236", "itemNumber": "AS00110", "itemDescription": "Edge Router X", "itemCategory": "Hardware.Network", "supplier": "EIP Inc", "buyer": "Developer, Rite", "assignee": "Jack", "promisedDate": "20-May-2025", "needByDate": "18-May-2025", "actualDate": "", "status": "WIP" }
      ]
    },
    "poSchedulesAllArray": { "type": "any[]", "defaultValue": [] },
    "poSchedulesADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": { "itemType": "any", "keyAttributes": "id", "data": "{{ $page.variables.poSchedulesArray }}" }
    },

    "filterCriterion": { "type": "any" },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": { "url": "[[ $application.path + 'resources/data/expedite-search-config.json' ]]" }
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "ProjectNumberFilter": { "label": "Project Number", "options": {
              "optionsData": "[[ $page.variables.projectNumberADP ]]", "optionsKeys": { "label": "label", "value": "value" } } },
            "BusinessUnitFilter": { "label": "Business Unit", "options": {
              "optionsData": "[[ $page.variables.businessUnitADP ]]", "optionsKeys": { "label": "label", "value": "value" } } },
            "ProjectOrgFilter": { "label": "Project Organization", "options": {
              "optionsData": "[[ $page.variables.projectOrgADP ]]", "optionsKeys": { "label": "label", "value": "value" } } },
            "CriticalFilter": { "label": "Critical", "options": {
              "optionsData": "[[ $page.variables.criticalOptionsADP ]]", "optionsKeys": { "label": "label", "value": "value" } } },
            "AssigneeFilter": { "label": "Assignee", "options": {
              "optionsData": "[[ $page.variables.assigneeADP ]]", "optionsKeys": { "label": "label", "value": "value" } } }
          }
        }
      }
    }
  },
  "metadata": {},
  "types": {},
  "chains": {
    "secondaryActionChain": {
      "variables": { "detail": { "type": "any", "input": "fromCaller", "required": true } }
    }
  },
  "eventListeners": {
    "vbEnter": { "chains": [ { "chain": "vbEnterChain" } ] },
    "spGoToParent": { "chains": [ { "chainId": "goToParentChain" } ] },
    "spPrimaryAction": { "chains": [ { "chainId": "primaryActionChain" } ] },
    "spSecondaryAction": { "chains": [ { "chainId": "secondaryActionChain", "parameters": { "detail": "{{ $event.detail }}" } } ] },
    "filterCriterionChanged": { "chains": [ { "chain": "filterChain" } ] }
  },
  "imports": {
    "components": {
      "oj-sp-general-overview-page": { "path": "oj-sp/general-overview-page/loader" },
      "oj-sp-smart-search": { "path": "oj-sp/smart-search/loader" },
      "oj-table": { "path": "ojs/ojtable" },
      "oj-bind-text": { "path": "ojs/ojknockout" },
      "oj-bind-if": { "path": "ojs/ojknockout" }
    }
  }
}
