{
  "title": "Oracle Requisition",
  "description": "Read-only requisition drill-back from Oracle (mock data pending ORDS/Fusion).",
  "variables": {
    "pageTitle": {
      "type": "string",
      "defaultValue": "Oracle Requisition"
    },
    "pageSubtitle": {
      "type": "string",
      "defaultValue": "Read-only requisition drill-back from Oracle"
    },
    "contextualInfo": {
      "type": "any[]",
      "defaultValue": [
        {
          "label": "Requisitions",
          "value": "4"
        },
        {
          "label": "Approved",
          "value": "2"
