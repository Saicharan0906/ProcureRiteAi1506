        {
          "label": "Pending",
          "value": "1"
        },
        {
          "label": "Incomplete",
          "value": "1"
        }
      ]
    },
    "badge": {
      "type": "object",
      "defaultValue": {
        "text": "Drill-back",
        "status": "info"
      }
    },
    "planHeader": {
      "type": "object",
      "defaultValue": {
        "projectName": "",
        "businessUnit": "",
        "projectOrg": "",
        "projectManager": ""
      }
    },
    "lastProjectNumber": {
      "type": "string",
      "defaultValue": ""
    },
    "projectMeta": {
      "type": "object",
      "defaultValue": {
        "P012025": {
          "projectName": "Pinnacle Park Project",
          "businessUnits": [
            "US1 Business Unit"
          ],
          "orgs": [
            "Consulting US"
          ],
          "projectManager": "Rite Developer"
        },
        "P012026": {
          "projectName": "Riverside Expansion",
