  "metadata": {},
  "types": {},
  "chains": {},
  "eventListeners": {
    "vbEnter": {
      "chains": [
        {
          "chain": "vbEnterChain"
        }
      ]
    },
    "spGoToParent": {
      "chains": [
        {
          "chainId": "goToParentChain"
        }
      ]
    },
    "spPrimaryAction": {
      "chains": [
        {
          "chainId": "primaryActionChain"
        }
      ]
    },
    "filterCriterionChanged": {
      "chains": [
        {
          "chain": "filterChain"
        }
      ]
    }
  },
  "imports": {
    "components": {
      "oj-sp-general-overview-page": {
        "path": "oj-sp/general-overview-page/loader"
      },
      "oj-sp-smart-search": {
        "path": "oj-sp/smart-search/loader"
      },
      "oj-table": {
        "path": "ojs/ojtable"
      },
      "oj-bind-text": {
        "path": "ojs/ojknockout"
      },
      "oj-bind-if": {
        "path": "ojs/ojknockout"
      }
    }
  }
