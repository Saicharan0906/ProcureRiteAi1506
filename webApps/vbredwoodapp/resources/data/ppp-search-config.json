{
  "description": "Project Procurement Plan smart search configuration",
  "options": { "keyword": "on" },
  "filters": {
    "StatusFilter": {
      "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
      "label": "Status",
      "options": {
        "field": "status",
        "optionsData": "[[ $search.filters.StatusFilter.options.optionsData ]]",
        "optionsKeys": "[[ $search.filters.StatusFilter.options.optionsKeys ]]"
      },
      "data": {}
    },
    "CriticalFilter": {
      "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
      "label": "Critical",
      "options": {
        "field": "critical",
        "optionsData": "[[ $search.filters.CriticalFilter.options.optionsData ]]",
        "optionsKeys": "[[ $search.filters.CriticalFilter.options.optionsKeys ]]"
      },
      "data": {}
    },
    "ItemCategoryFilter": {
      "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
      "label": "Item Category",
      "options": {
        "field": "itemCategory",
        "optionsData": "[[ $search.filters.ItemCategoryFilter.options.optionsData ]]",
        "optionsKeys": "[[ $search.filters.ItemCategoryFilter.options.optionsKeys ]]"
      },
      "data": {}
    },
    "BuyerFilter": {
      "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
      "label": "Buyer",
      "options": {
        "field": "buyer",
        "optionsData": "[[ $search.filters.BuyerFilter.options.optionsData ]]",
        "optionsKeys": "[[ $search.filters.BuyerFilter.options.optionsKeys ]]"
      },
      "data": {}
    }
  }
}
