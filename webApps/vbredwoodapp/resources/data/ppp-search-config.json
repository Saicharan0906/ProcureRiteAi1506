{
  "description": "Project Procurement Plan smart search configuration (filters mirror the original page search header)",
  "filters": {
    "ProjectNumberFilter": {
      "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
      "label": "Project Number",
      "options": {
        "field": "projectNumber",
        "optionsData": "[[ $search.filters.ProjectNumberFilter.options.optionsData ]]",
        "optionsKeys": "[[ $search.filters.ProjectNumberFilter.options.optionsKeys ]]"
      },
      "data": {}
    },
    "BusinessUnitFilter": {
      "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
      "label": "Business Unit",
      "options": {
        "field": "businessUnit",
        "optionsData": "[[ $search.filters.BusinessUnitFilter.options.optionsData ]]",
        "optionsKeys": "[[ $search.filters.BusinessUnitFilter.options.optionsKeys ]]"
      },
      "data": {}
    },
    "ProjectOrgFilter": {
      "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
      "label": "Project Organization",
      "options": {
        "field": "projectOrg",
        "optionsData": "[[ $search.filters.ProjectOrgFilter.options.optionsData ]]",
        "optionsKeys": "[[ $search.filters.ProjectOrgFilter.options.optionsKeys ]]"
      },
      "data": {}
    },
    "ItemCategoryFilter": {
      "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
      "label": "Item Category",
      "options": {
        "field": "itemCategory",
        "optionsData": "[[ $search.filters.ItemCategoryFilter.options.optionsData ]]",
        "optionsKeys": "[[ $search.filters.ItemCategoryFilter.options.optionsKeys ]]"
      },
      "data": {}
    },
    "BuyerFilter": {
      "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
      "label": "Buyer",
      "options": {
        "field": "buyer",
        "optionsData": "[[ $search.filters.BuyerFilter.options.optionsData ]]",
        "optionsKeys": "[[ $search.filters.BuyerFilter.options.optionsKeys ]]"
      },
      "data": {}
    },
    "RequestedDateFilter": {
      "type": "oj-sp/smart-search/default-filters/DateRangeFilter",
      "label": "Requested Delivery Date",
      "options": { "field": "requested_delivery_date", "min": "2000-01-01", "max": "2035-12-31" },
      "data": {}
    }
  }
}
